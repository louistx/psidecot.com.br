name: dockercompose11133801694074045554
services:
  db:
    environment:
      POSTGRES_DB: psidecot
      POSTGRES_PASSWORD: Dev123!
      POSTGRES_USER: psidecot
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U psidecot -d psidecot
      timeout: 5s
      interval: 5s
      retries: 5
    image: postgres:17-alpine
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5433"
        protocol: tcp
    volumes:
      - type: volume
        source: pgdata
        target: /var/lib/postgresql/data
        volume: {}
  psidecot.admin:
    build:
      context: C:\coxas\PsiDecot\src\PsiDecot.Admin
      dockerfile: Dockerfile
    depends_on:
      psidecot.api:
        condition: service_started
        required: true
    image: psidecotadmin
    networks:
      default: null
    ports:
      - mode: ingress
        target: 80
        published: "5173"
        protocol: tcp
  psidecot.api:
    build:
      context: C:\coxas\PsiDecot\src
      dockerfile: PsiDecot.Api/Dockerfile
    depends_on:
      db:
        condition: service_healthy
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: http://+:8080
      ConnectionStrings__Default: Host=db;Port=5432;Database=psidecot;Username=psidecot;Password=Dev123!;Search Path=psidecot
      Cors__Origins__0: http://192.168.100.11:5173
      Jwt__Audience: psidecot-web
      Jwt__Issuer: psidecot-api
      Jwt__Key: super-secret-dev-key-that-is-long-enough-32chars!
    image: psidecotapi
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
  psidecot.website:
    build:
      context: C:\coxas\PsiDecot\src\PsiDecot.Website
      dockerfile: Dockerfile
    depends_on:
      psidecot.api:
        condition: service_started
        required: true
    image: psidecotwebsite
    networks:
      default: null
    ports:
      - mode: ingress
        target: 3000
        published: "3000"
        protocol: tcp
networks:
  default:
    name: dockercompose11133801694074045554_default
volumes:
  pgdata:
    name: dockercompose11133801694074045554_pgdata